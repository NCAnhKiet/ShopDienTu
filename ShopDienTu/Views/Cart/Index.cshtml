@model List<ShopDienTu.MoDels.CartDetail>

@{
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
    ViewData["Title"] = "Giỏ hàng của bạn";
    decimal totalSum = 0;
}

<div class="mb-4">
    <h3 class="fw-bold m-0" style="color: var(--text-main);">GIỎ HÀNG CỦA TÔI</h3>
</div>

@if (Model == null || !Model.Any())
{
    <div class="bg-white rounded-4 shadow-sm p-5 text-center">
        <div class="mb-3">
            <i class="bi bi-cart-x text-muted" style="font-size: 4rem; opacity: 0.3;"></i>
        </div>
        <h4 class="fw-bold text-dark mb-2">Giỏ hàng của bạn đang trống</h4>
        <p class="text-muted mb-4">Hãy chọn cho mình bộ sản phẩm công nghệ ưng ý nhất nhé.</p>
        <a href="/Product" class="btn text-white fw-bold px-4 py-2" style="background: var(--accent); border-radius: 8px;">Tiếp tục mua sắm</a>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="bg-white rounded-4 shadow-sm p-4">
                <div class="table-responsive">
                    <table class="table align-middle mb-0 border-0">
                        <thead>
                            <tr class="text-muted" style="font-size: 0.8rem; text-transform: uppercase;">
                                <th scope="col" class="border-0 pb-3">Sản phẩm</th>
                                <th scope="col" class="border-0 pb-3" style="min-width: 120px;">Đơn giá</th>
                                <th scope="col" class="border-0 pb-3 text-center" style="min-width: 120px;">Số lượng</th>
                                <th scope="col" class="border-0 pb-3 text-end" style="min-width: 140px;">Thành tiền</th>
                                <th scope="col" class="border-0 pb-3 text-end"></th>
                            </tr>
                        </thead>
                        <tbody class="border-top-0">
                            @foreach (var item in Model)
                            {
                                var price = item.Product.Price ?? 0;
                                var lineTotal = item.Quantity * price;
                                totalSum += lineTotal;
                                var imgSrc = string.IsNullOrEmpty(item.Product.ImageUrl) ? "" 
                                    : (item.Product.ImageUrl.StartsWith("/") ? item.Product.ImageUrl : Url.Content("~/ProductsImages/" + item.Product.ImageUrl));

                                <tr>
                                    <td class="py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 70px; height: 70px; flex-shrink: 0;">
                                                <img src="@imgSrc" class="img-fluid" style="max-height: 55px; object-fit: contain;" onerror="this.style.display='none'">
                                            </div>
                                            <div>
                                                <a href="/Home/ChiTietSanPham?productId=@item.ProductId" class="fw-bold text-dark text-decoration-none d-block mb-1">@item.Product.ProductName</a>
                                                <span class="badge text-bg-light text-muted border">@item.Product.Color / @(string.IsNullOrEmpty(item.Product.Size) ? "MĐ" : item.Product.Size)</span>
                                            </div>
                                        </div>
                                    </td>
                                    
                                    <td class="py-3 fw-semibold">@String.Format("{0:N0}₫", item.Product.Price)</td>
                                    
                                    <td class="py-3">
                                        <form method="post" action="/Cart/UpdateQuantity" class="d-inline-flex justify-content-center align-items-center m-0">
                                            <input type="hidden" name="id" value="@item.CartDetailId" />
                                            <div class="input-group input-group-sm" style="width: 100px;">
                                                <input type="number" name="quantity" class="form-control text-center shadow-none border-secondary-subtle" value="@item.Quantity" min="1" onchange="this.form.submit()" />
                                            </div>
                                            <noscript><button class="btn btn-sm btn-outline-secondary ms-1">Cập nhật</button></noscript>
                                        </form>
                                    </td>
                                    
                                    <td class="py-3 text-end fw-bolder" style="color: var(--accent);">@String.Format("{0:N0}₫", lineTotal)</td>
                                    
                                    <td class="py-3 text-end">
                                        <form method="post" action="/Cart/Remove" class="m-0">
                                            <input type="hidden" name="id" value="@item.CartDetailId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger border-0" title="Xóa" onclick="return confirm('Bạn có chắc muốn xóa?')">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="bg-white rounded-4 shadow-sm p-4 sticky-top" style="top: 80px;">
                <h5 class="fw-bold mb-4 border-bottom pb-3">Tóm tắt đơn hàng</h5>
                
                <div class="d-flex justify-content-between mb-3 text-muted">
                    <span>Tạm tính</span>
                    <span class="fw-semibold text-dark">@String.Format("{0:N0}₫", totalSum)</span>
                </div>
                <div class="d-flex justify-content-between mb-3 text-muted">
                    <span>Phí giao hàng</span>
                    <span class="fw-semibold text-dark">Miễn phí</span>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mb-4 mt-4 pt-3 border-top">
                    <span class="fw-bold text-dark">Tổng cộng</span>
                    <span class="fs-4 fw-black" style="color: var(--accent); font-weight: 900;">@String.Format("{0:N0}₫", totalSum)</span>
                </div>
                
                <a href="/Checkout" class="btn text-white w-100 fw-bold py-2 mb-3 shadow" style="background: var(--accent); border-radius: 8px;">TIẾN HÀNH THANH TOÁN</a>
                <a href="/Product" class="btn btn-light w-100 fw-bold py-2 text-muted" style="border-radius: 8px;">Tiếp tục mua sắm</a>
            </div>
        </div>
    </div>
}
