@{
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="row justify-content-center pt-4 pb-5">
    <div class="col-lg-6 col-md-8 text-center">
        <div class="bg-white rounded-4 shadow-sm p-5">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
            </div>
            
            <h2 class="fw-bold text-dark mb-3">Đặt Hàng Thành Công!</h2>
            <p class="text-muted mb-4" style="font-size: 0.95rem; line-height: 1.6;">
                Cảm ơn bạn đã mua sắm tại <strong>Shop Điện Tử</strong>.<br>
                Đơn hàng của bạn đã được ghi nhận và đang trong quá trình xử lý. Chúng tôi sẽ sớm liên hệ để xác nhận giao hàng.
            </p>
            
            <div class="d-flex justify-content-center gap-3">
                <a href="/Order/MyOrders" class="btn btn-outline-secondary fw-bold px-4 py-2" style="border-radius: 8px;">Theo dõi đơn hàng</a>
                <a href="/Product" class="btn text-white fw-bold px-4 py-2" style="background: var(--accent); border-radius: 8px;">Tiếp tục mua sắm</a>
            </div>
        </div>
    </div>
</div>
