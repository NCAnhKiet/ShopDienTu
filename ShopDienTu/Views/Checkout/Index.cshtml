@{
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
    ViewData["Title"] = "Thanh toán";
    var customer = ViewBag.Customer as ShopDienTu.MoDels.Customer;
}

<div class="mb-4">
    <h3 class="fw-bold m-0" style="color: var(--text-main);">THÔNG TIN THANH TOÁN</h3>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="bg-white rounded-4 shadow-sm p-4 p-md-5">
            <div class="d-flex align-items-center mb-4">
                <i class="bi bi-shield-check text-success fs-3 me-3"></i>
                <h5 class="fw-bold m-0 text-dark">Bảo mật thông tin giao hàng</h5>
            </div>
            
            <form method="post" asp-action="Confirm">
                
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Tên người nhận <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                            <input type="text" name="ReceiverName" class="form-control bg-light border-start-0 ps-0 shadow-none" value="@customer?.FullName" placeholder="Nhập họ tên" required />
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Số điện thoại <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-telephone text-muted"></i></span>
                            <input type="text" name="Phone" class="form-control bg-light border-start-0 ps-0 shadow-none" value="@customer?.Phone" placeholder="Ví dụ: 0901234567" required />
                        </div>
                    </div>
                    
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 align-items-start pt-2"><i class="bi bi-geo-alt text-muted"></i></span>
                            <textarea name="Address" class="form-control bg-light border-start-0 ps-0 shadow-none pt-2" rows="3" placeholder="Nhập địa chỉ nhận hàng chi tiết" required>@customer?.Address</textarea>
                        </div>
                    </div>
                </div>

                <div class="bg-light p-3 rounded-3 mb-4 border d-flex gap-3 align-items-center">
                    <i class="bi bi-truck fs-4" style="color: var(--accent);"></i>
                    <div>
                        <div class="fw-bold text-dark" style="font-size: 0.9rem;">Giao hàng tiêu chuẩn (Miễn phí)</div>
                        <div class="text-muted" style="font-size: 0.8rem;">Dự kiến nhận hàng chậm nhất sau 3 - 5 ngày làm việc.</div>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mt-4 pt-4 border-top">
                    <a href="/Cart" class="text-muted text-decoration-none fw-semibold">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại
                    </a>
                    <button class="btn text-white px-5 py-2 fw-bold shadow-sm" style="background: var(--accent); border-radius: 8px;">
                        XÁC NHẬN ĐẶT HÀNG
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>