<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ShopDienTu</title>

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- FONT AWESOME -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <!-- INLINE CSS (Style C: trắng – xám – minimal) -->
    <link rel="stylesheet" href="~/1LayoutShopDienTu/css/shopdientu.css" />

</head>

<body>

    <!-- HEADER -->
    <header class="header">
        <div class="header__top">
            <div class="container">
                <ul>
                    <li><i class="fa fa-envelope"></i> support@shopdientu.com</li>
                    <li>Miễn phí vận chuyển đơn từ 500k</li>
                </ul>
            </div>
        </div>

        <div class="container header__main">
            <div class="header__logo">
                <a href="/"><img src="../1LayoutShopDienTu/images/shopdientu.png" /></a>
            </div>

            <nav class="header__menu">
                <ul>
                    <li class="active"><a href="/">Trang chủ</a></li>
                    <li><a href="/Product">Sản phẩm</a></li>
                    <li>
                        <a href="/Order/MyOrders">Đơn hàng của tôi</a>
                    </li>
                    @* <li><a href="/Cart">Giỏ hàng</a></li> *@
                    @* <li><a href="#">Liên hệ</a></li> *@
                </ul>
            </nav>

            <div class="header__cart d-flex align-items-center gap-3">

                <a href="/Cart" class="cart-link">
                    <i class="fa fa-shopping-cart"></i> <span id="cartCount">0</span>
                </a>



                @if (Context.Session.GetString("Email") != null)
                {
                    <!-- ĐÃ ĐĂNG NHẬP → Hiện Logout -->
                    <a href="/Access/Logout" class="logout-link">
                        <i class="fa fa-sign-out-alt"></i> Logout
                    </a>
                }
                else
                {
                    <!-- CHƯA ĐĂNG NHẬP → Hiện Login + Register -->
                    <a href="/Access/Login" class="logout-link">
                        <i class="fa fa-sign-in-alt"></i> Login
                    </a>

                    <a href="/Access/Register" class="logout-link">
                        <i class="fa fa-user-plus"></i> Register
                    </a>
                }

            </div>


        </div>
    </header>

    <!-- HERO -->
    <section class="hero">
        <div class="container">
            <div class="hero__grid">

                <!-- category -->
                @await Component.InvokeAsync("CategoriesMenu")

                <!-- banner -->
                <div class="hero__banner set-bg"
                     data-setbg="@Url.Content("~/1LayoutShopDienTu/images/banner-electronic.jpg")">

                    @* <div class="hero__text">
                        <span>SẢN PHẨM CÔNG NGHỆ</span>
                        <h2>GIÁ TỐT • CHẤT LƯỢNG</h2>
                        <p>Cam kết chính hãng 100%</p>
                        <a href="/Product" class="primary-btn">XEM NGAY</a>
                    </div> *@
                </div>

            </div>
        </div>
    </section>

    <!-- FEATURED -->
    @if (ViewBag.HideFeatured != true){
    <section class="featured">
        <div class="container">
                <h2 class="section-title text-center"
                    style="font-weight:700; font-size:50px; color:#0ea5a4; margin:35px 0;">
                    @(ViewBag.FeaturedTitle ?? "Sản phẩm nổi bật")
                </h2>

            <div class="featured__grid">
                <!-- LOOP FROM DATABASE -->
                @RenderBody()
            </div>
        </div>
        </section>
    }
    else
    {
        <main class="container py-4">
            @RenderBody()
        </main>
    }

    <!-- FOOTER -->
    <footer class="footer">
        <div class="container">
            <div class="footer__content d-flex justify-content-between">
                <div class="footer__about">
                    <ul>
                        <li>Địa chỉ: 9 Trần Bích San, TP.Đà Nẵng</li>
                        <li>Phone: 0909.999.999</li>
                        <li>Email: support@shopdientu.com</li>
                    </ul>
                </div>

                <div class="footer__links">
                    <h6>Liên kết nhanh</h6>
                    <a href="/">Trang chủ</a>
                    <a href="/Product">Sản phẩm</a>
                    <a href="/Cart">Giỏ hàng</a>
                    <a href="#">Liên hệ</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- BOOTSTRAP JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- INLINE JS -->
    <script src="~/1LayoutShopDienTu/js/shopdientu.js"></script>

</body>

</html>
