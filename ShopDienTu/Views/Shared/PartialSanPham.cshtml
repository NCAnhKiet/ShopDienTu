@model ShopDienTu.MoDels.Product
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    var imgSrc = string.IsNullOrEmpty(Model.ImageUrl) ? "" 
        : (Model.ImageUrl.StartsWith("/") ? Model.ImageUrl : Url.Content("~/ProductsImages/" + Model.ImageUrl));
}

<div class="card h-100 border-0 shadow-sm" style="border-radius: 12px; overflow: hidden; transition: 0.3s; cursor: pointer;" 
     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.08)';" 
     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 .125rem .25rem rgba(0,0,0,.075)';"
     onclick="window.location='/Home/ChiTietSanPham?productId=@Model.ProductId'">
     
    <div class="bg-light position-relative d-flex align-items-center justify-content-center p-3" style="height: 180px;">
        @if (!string.IsNullOrEmpty(imgSrc))
        {
            <img src="@imgSrc" alt="@Model.ProductName" class="img-fluid" style="max-height: 100%; object-fit: contain; transition: transform 0.3s;"
                 onmouseover="this.style.transform='scale(1.05)';" onmouseout="this.style.transform='scale(1)';" onerror="this.style.display='none'" />
        }
        else
        {
            <i class="bi bi-image text-muted" style="font-size: 3rem; opacity: 0.3;"></i>
        }
    </div>

    <div class="card-body p-3 d-flex flex-column">
        <h6 class="card-title fw-bold text-dark text-truncate mb-1" title="@Model.ProductName">@Model.ProductName</h6>
        
        <div class="text-muted d-flex justify-content-between" style="font-size: 0.75rem; margin-bottom: auto;">
            <span>@Model.Color @(string.IsNullOrEmpty(Model.Size) ? "" : " • " + Model.Size)</span>
            <span style="color: #64748b; font-weight: 600;">Đã bán @Model.SoldCount</span>
        </div>
        
        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="fs-6 fw-bolder" style="color: var(--accent);">@String.Format("{0:N0}₫", Model.Price)</span>
            <a asp-controller="Home" asp-action="ChiTietSanPham" asp-route-productId="@Model.ProductId" 
               class="btn btn-sm text-white px-2 py-1" style="background: var(--text-main); border-radius: 6px; font-size: 0.75rem; font-weight: 600;" onclick="event.stopPropagation();">
                Chi tiết
            </a>
        </div>
    </div>
</div>
