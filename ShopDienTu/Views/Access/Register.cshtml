@model ShopDienTu.MoDels.Customer
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Đăng Ký - ShopDienTu</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f1f5f9;
            color: #1e293b;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 0;
        }
        .auth-card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            padding: 2.5rem 3rem;
            width: 100%;
            max-width: 500px;
        }
        .form-control {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-size: 0.95rem;
        }
        .form-control:focus {
            box-shadow: none;
            border-color: #0ea5a4;
            background-color: #ffffff;
        }
        .btn-primary {
            background: linear-gradient(135deg, #0ea5a4, #0b8281);
            border: none;
            border-radius: 8px;
            padding: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            transition: 0.2s;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(14, 165, 164, 0.4);
        }
        .btn-home {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 0.8rem;
            border-radius: 8px;
            border: 1.5px solid #0ea5a4;
            color: #0ea5a4;
            background: transparent;
            font-weight: 700;
            text-decoration: none;
            transition: 0.2s;
        }
        .btn-home:hover {
            background: #0ea5a4;
            color: #ffffff;
        }
    </style>
</head>
<body>

    <div class="auth-card">
        <div class="text-center mb-4">
            <h2 class="fw-black mb-1" style="color: #0ea5a4; font-weight: 900; font-size: 2rem;">ĐĂNG KÝ MỚI</h2>
            <p class="text-muted" style="font-size: 0.95rem;">Bạn là người mới? Việc tạo tài khoản rất dễ dàng.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger rounded-3" style="font-size: 0.9rem;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
            </div>
        }

        @using (Html.BeginForm("Register", "Access", FormMethod.Post))
        {
            <div class="mb-3">
                <label class="form-label fw-bold text-muted small text-uppercase">Họ tên đầy đủ <span class="text-danger">*</span></label>
                <input type="text" name="FullName" class="form-control" placeholder="Nhập họ và tên" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold text-muted small text-uppercase">Email đăng nhập <span class="text-danger">*</span></label>
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "ví dụ: nva@gmail.com", required = "required" })
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold text-muted small text-uppercase">Mật khẩu <span class="text-danger">*</span></label>
                @Html.TextBoxFor(m => m.Password, new { @class = "form-control", type = "password", placeholder = "Tạo mật khẩu", required = "required" })
            </div>

            <div class="row gx-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold text-muted small text-uppercase">Số điện thoại</label>
                    @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", placeholder = "Số điện thoại" })
                </div>
                <div class="col-md-6 mt-3 mt-md-0">
                    <label class="form-label fw-bold text-muted small text-uppercase">Địa chỉ</label>
                    @Html.TextBoxFor(m => m.Address, new { @class = "form-control", placeholder = "Địa chỉ nhận hàng" })
                </div>
            </div>

            <div class="mb-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="termsCheck" required style="cursor: pointer;">
                    <label class="form-check-label text-muted" for="termsCheck" style="font-size: 0.85rem; cursor: pointer;">
                        Tôi đồng ý với tất cả các <a href="#" style="color: #0ea5a4; text-decoration: none;">điều khoản & chính sách</a>
                    </label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-3 text-white">ĐĂNG KÝ TÀI KHOẢN</button>
        }

        <a href="/" class="btn-home mb-4"><i class="bi bi-house-door-fill me-2"></i> Về trang chủ</a>

        <div class="text-center text-muted" style="font-size: 0.9rem;">
            Bạn đã có tài khoản rồi? <a asp-controller="Access" asp-action="Login" class="fw-bold text-decoration-none" style="color: #0ea5a4;">Đăng nhập</a>
        </div>
    </div>

</body>
</html>
